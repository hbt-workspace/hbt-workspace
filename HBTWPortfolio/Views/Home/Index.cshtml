@{
    ViewData["Title"] = "HBT Workspace";
    Layout = null;
    int inceptionYear = 2026; // Set the inception year of the company
    int currentYear = DateTime.Now.Year;
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Page Title -->
    <title>HBT Workspace</title>

    <!-- Meta Description -->
    <meta name="description"
          content="HBT Workspace is a modern software development company dedicated to delivering high-quality, scalable, and innovative digital solutions. We specialize in building custom web applications, enterprise systems, and user-friendly platforms tailored to meet business needs. Our focus is on performance, reliability, and seamless user experience, helping businesses grow in the digital era.">

    <!-- Meta Keywords -->
    <meta name="keywords"
          content="Software company in nagpur, Software company in kamptee, A sofware company, Software company, Software development, Website development, Mobile api development, Custom software solutions, Software consulting, IT services, Digital transformation, Software engineering">

    <!-- Author -->
    <meta name="author" content="Moiz Ahmed">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/slider.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</head>

<body>

    <!-- Carousel -->
    <div id="demo" class="carousel slide" data-bs-ride="carousel">

        <!-- Indicators/dots -->
        <div class="carousel-indicators">
            <button type="button" data-bs-target="#demo" data-bs-slide-to="0" class="active"></button>
            <button type="button" data-bs-target="#demo" data-bs-slide-to="1"></button>
            <button type="button" data-bs-target="#demo" data-bs-slide-to="2"></button>
            <button type="button" data-bs-target="#demo" data-bs-slide-to="3"></button>
            <button type="button" data-bs-target="#demo" data-bs-slide-to="4"></button>
        </div>
  
        <!-- The slideshow/carousel -->
        <div class="carousel-inner">
            <div class="carousel-item active">
                <img src="images/1.png" alt="About HBT Workspace" class="d-block" style="width:100%">
            </div>
            <div class="carousel-item">
                <img src="images/2.png" alt="Why HBT Workspace?" class="d-block" style="width:100%">
            </div>
            <div class="carousel-item">
                <img src="images/3.png" alt="Our Projects" class="d-block" style="width:100%">
            </div>
            <div class="carousel-item">
                <img src="images/4.png" alt="Our Services" class="d-block" style="width:100%">
            </div>
            <div class="carousel-item">
                <img src="images/5.png" alt="Contact Us" class="d-block" style="width:100%">
            </div>
        </div>
  
        <!-- Left and right controls/icons -->
        <button class="carousel-control-prev" type="button" data-bs-target="#demo" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#demo" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
        </button>
    </div>

    <div class="carousel-caption-custom">
        Copyright © @((inceptionYear == currentYear) ? inceptionYear : $"{inceptionYear}-{currentYear}") HBT Workspace.
        All rights reserved.
    </div>

    <a href="https://wa.me/919172499704" target="_blank" class="whatsapp-float">
        <i class="bi bi-whatsapp"></i>
    </a>
</body>

</html>
